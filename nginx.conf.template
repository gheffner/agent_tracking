server {
  listen 80;
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  # Static dashboards + assets
  location / {
    try_files $uri $uri/ =404;
  }

  # --- SQL proxies -----------------------------------------------------------
  # The browser POSTs {sql, params} to these same-origin paths. nginx forwards
  # to the internal AWS API Gateway and injects the identity + secret headers,
  # so the credential never reaches the client.

  # agent_platform DB: runs, decisions, core, observations…
  location = /api/sql {
    if ($request_method != POST) { return 405; }
    proxy_method POST;
    proxy_pass https://1r7hjb5jv6.execute-api.us-east-1.amazonaws.com/prod/db/agent_platform/sql;
    proxy_set_header Host              1r7hjb5jv6.execute-api.us-east-1.amazonaws.com;
    proxy_set_header X-Identity        "${SQL_IDENTITY}";
    proxy_set_header X-Internal-Secret "${SQL_SECRET}";
    proxy_set_header Content-Type      "application/json";
    proxy_ssl_server_name on;
  }

  # webhooks DB: webhook_events, oauth tokens…
  location = /api/webhooks/sql {
    if ($request_method != POST) { return 405; }
    proxy_method POST;
    proxy_pass https://1r7hjb5jv6.execute-api.us-east-1.amazonaws.com/prod/db/webhooks/sql;
    proxy_set_header Host              1r7hjb5jv6.execute-api.us-east-1.amazonaws.com;
    proxy_set_header X-Identity        "${SQL_IDENTITY}";
    proxy_set_header X-Internal-Secret "${SQL_SECRET}";
    proxy_set_header Content-Type      "application/json";
    proxy_ssl_server_name on;
  }
}
