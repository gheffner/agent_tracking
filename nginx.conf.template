server {
  listen 80;
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  # Static dashboards + assets. no-cache = browsers must revalidate with the
  # server on each load (conditional GET → 304 if unchanged), so a deploy never
  # leaves a stale common.js / risk.js / styles.css in a client cache.
  location / {
    add_header Cache-Control "no-cache";
    try_files $uri $uri/ =404;
  }

  # --- SQL proxies -----------------------------------------------------------
  # The browser POSTs {sql, params} to these same-origin paths. nginx forwards
  # to the internal SQL proxy API Gateway and injects the identity + secret
  # headers, so the credential never reaches the client.
  #
  # SQL_API_BASE, SQL_IDENTITY and SQL_SECRET are substituted from the
  # container's runtime env vars by the official nginx image's entrypoint
  # (text substitution at startup), so no internal URL or credential lives in
  # this repo. SQL_API_BASE is the API Gateway base, e.g.
  #   https://XXXXXXXX.execute-api.<region>.amazonaws.com/prod
  # The Host header is derived automatically from SQL_API_BASE ($proxy_host).

  # agent_platform DB: runs, decisions, core, observations…
  location = /api/sql {
    if ($request_method != POST) { return 405; }
    proxy_method POST;
    proxy_pass ${SQL_API_BASE}/db/agent_platform/sql;
    proxy_set_header X-Identity        "${SQL_IDENTITY}";
    proxy_set_header X-Internal-Secret "${SQL_SECRET}";
    proxy_set_header Content-Type      "application/json";
    proxy_ssl_server_name on;
  }

  # webhooks DB: webhook_events, oauth tokens…
  location = /api/webhooks/sql {
    if ($request_method != POST) { return 405; }
    proxy_method POST;
    proxy_pass ${SQL_API_BASE}/db/webhooks/sql;
    proxy_set_header X-Identity        "${SQL_IDENTITY}";
    proxy_set_header X-Internal-Secret "${SQL_SECRET}";
    proxy_set_header Content-Type      "application/json";
    proxy_ssl_server_name on;
  }
}
